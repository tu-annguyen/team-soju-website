# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/team_soju
DB_HOST=localhost
DB_PORT=5432
DB_NAME=team_soju
DB_USER=username
DB_PASSWORD=password

# Server Configuration
PORT=3001
API_BASE_URL=http://localhost:3001/api
API_ORIGIN=http://localhost:3001
WEB_APP_URL=http://localhost:4321
NODE_ENV=development

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-here
DISCORD_API_TOKEN=your-discord-api-token-here

# Web App Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id-here
DISCORD_CLIENT_SECRET=your-discord-client-secret-here
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/discord/callback

# Discord Bot Configuration
DISCORD_PUBLIC_KEY=your-discord-public-key-here
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_GUILD_ID=your-discord-guild-id-here
BOT_API_TOKEN=your-bot-api-token-here
REGISTER_COMMANDS_ON_START=true

# Worker screenshot callback configuration
SCREENSHOT_RESULT_CALLBACK_URL=your-screenshot-result-callback-url-here
SCREENSHOT_RESULT_CALLBACK_SECRET=your-screenshot-result-callback-secret-here
