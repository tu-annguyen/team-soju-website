# Team Soju environment template
#
# Copy this file to .env for local Node/Discord development.
# For deployed Workers, put non-secret values in wrangler.jsonc and set secrets
# separately per environment with Wrangler, for example:
#   npx wrangler secret put JWT_SECRET --config apps/api-server/wrangler.jsonc --env staging
#   npx wrangler secret put DISCORD_TOKEN --config apps/discord-bot/wrangler.jsonc --env staging

# Shared runtime
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-here
AUTH_COOKIE_NAME=team_soju_session

# Local Node API server
PORT=3001
API_ORIGIN=http://localhost:3001
WEB_APP_URL=http://localhost:4321
FRONTEND_URL=http://localhost:4321
CORS_ORIGINS=http://localhost:3000,http://localhost:4321
# Staging API origin example:
# API_ORIGIN=https://team-soju-api-staging.tunacore.workers.dev
# Production API origin example:
# API_ORIGIN=https://team-soju-api.tunacore.workers.dev

# API client targets for the frontend and Discord bot
API_BASE_URL=http://localhost:3001/api
PUBLIC_API_BASE_URL=http://localhost:3001/api
# Staging examples:
# API_BASE_URL=https://team-soju-api-staging.tunacore.workers.dev/api
# PUBLIC_API_BASE_URL=https://team-soju-api-staging.tunacore.workers.dev/api
# Production examples:
# API_BASE_URL=https://team-soju-api.tunacore.workers.dev/api
# PUBLIC_API_BASE_URL=https://team-soju-api.tunacore.workers.dev/api

# Database configuration for legacy Node scripts and Postgres export helpers
DATABASE_URL=postgresql://username:password@localhost:5432/team_soju
DB_HOST=localhost
DB_PORT=5432
DB_NAME=team_soju
DB_USER=username
DB_PASSWORD=password
DB_SSL=false
DB_SSL_MODE=disable
PGSSLMODE=disable

# Cloudflare API Worker / D1
DB_BACKEND=d1
LEGACY_API_BASE_URL=https://team-soju-website.onrender.com

# Discord OAuth for web auth
DISCORD_CLIENT_ID=your-discord-client-id-here
DISCORD_CLIENT_SECRET=your-discord-client-secret-here
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/discord/callback
# Staging callback example:
# DISCORD_REDIRECT_URI=https://team-soju-api-staging.tunacore.workers.dev/api/auth/discord/callback
# Production callback example:
# DISCORD_REDIRECT_URI=https://team-soju-api.tunacore.workers.dev/api/auth/discord/callback

# Discord interaction Worker / local bot server
DISCORD_PUBLIC_KEY=your-discord-public-key-here
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_GUILD_ID=your-discord-guild-id-here
DISCORD_BOT_PORT=8787
REGISTER_COMMANDS_ON_START=true
BOT_API_TOKEN=your-bot-api-token-here
DISCORD_LOG_LEVEL=info
DISCORD_DEBUG_LOGS=false
DISCORD_BOT_HTTP_TIMEOUT_MS=15000
DISCORD_BOT_HTTP_RETRY_COUNT=2
DISCORD_BOT_HTTP_RETRY_DELAY_MS=250

# Screenshot/OCR migration bridge
# The Discord bot sends this callback URL to the API for async screenshot results.
SCREENSHOT_RESULT_CALLBACK_URL=http://localhost:8787/internal/screenshot-result
# Staging callback example:
# SCREENSHOT_RESULT_CALLBACK_URL=https://team-soju-discord-bot-staging.tunacore.workers.dev/internal/screenshot-result
# Production callback example:
# SCREENSHOT_RESULT_CALLBACK_URL=https://team-soju-discord-bot.tunacore.workers.dev/internal/screenshot-result
SCREENSHOT_RESULT_CALLBACK_SECRET=your-shared-screenshot-callback-secret-here
# The legacy Node screenshot/OCR route can write/read data through the Worker API.
SCREENSHOT_DATA_API_BASE_URL=https://team-soju-api-staging.tunacore.workers.dev/api
SCREENSHOT_DATA_API_BOT_TOKEN=worker-accepted-bot-token-here

# Email service
# Use "console" locally, or "resend"/"postmark" in deployed environments.
EMAIL_PROVIDER=console
EMAIL_FROM="Team Soju <no-reply@example.com>"
RESEND_API_KEY=resend-api-key-here
RESEND_FROM="Team Soju <no-reply@example.com>"
POSTMARK_SERVER_TOKEN=postmark-server-token-here
POSTMARK_FROM="Team Soju <no-reply@example.com>"
POSTMARK_MESSAGE_STREAM=outbound

# Optional IGN moderation
IGN_BLACKLIST=
IGN_SUBSTRING_BLACKLIST=
