{
  "name": "@team-soju/discord-bot",
  "version": "1.0.0",
  "description": "Discord bot for Team Soju - manages team members and shiny Pokemon",
  "main": "src/worker.js",
  "scripts": {
    "start": "node src/devServer.js",
    "dev": "node --watch src/devServer.js",
    "register": "node -e \"require('./src/worker').registerCommandsIfNeeded({ ...process.env, REGISTER_COMMANDS_ON_START: 'true' })\"",
    "deploy:cf": "wrangler deploy --config wrangler.jsonc",
    "deploy:cf:preview": "wrangler versions upload --config wrangler.jsonc",
    "test": "jest --runInBand --coverage"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "slash-commands",
    "pokemon",
    "team-soju"
  ],
  "author": "Tu-An Nguyen",
  "license": "MIT",
  "dependencies": {
    "@team-soju/utils": "^1.0.0",
    "axios": "^1.13.2",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "image-js": "^1.4.0",
    "pokeapi-js-wrapper": "^1.2.8",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "wrangler": "^4.75.0"
  }
}
