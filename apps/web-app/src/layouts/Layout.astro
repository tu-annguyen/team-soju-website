---
import '../styles/global.css';
import Header from '../components/Header';
import Footer from '../components/Footer';
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'
import { getTranslations, resolveLocale } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  locale?: string;
}

const { 
  title,
  description,
  locale: localeProp,
} = Astro.props;

const locale = resolveLocale(localeProp ?? Astro.url.searchParams.get('lang'));
const messages = getTranslations(locale);
const resolvedTitle = title ?? messages.meta.defaultTitle;
const resolvedDescription = description ?? messages.meta.defaultDescription;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={resolvedDescription} />
    <title>{resolvedTitle}</title>
    
    <!-- Prevent flash of unstyled content -->
    <script is:inline>
      const theme = localStorage.getItem('theme') || 
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>
  <body>
    <Analytics />
    <SpeedInsights />
    <Header client:load locale={locale} />
    <main class="pt-16">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
