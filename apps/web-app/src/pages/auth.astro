---
import Layout from '../layouts/Layout.astro';
import AuthPage from '../components/AuthPage';
import { getTranslations, resolveLocale } from '../i18n';

const locale = resolveLocale(Astro.url.searchParams.get('lang'));
const messages = getTranslations(locale);
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:3001/api';
---

<Layout
  locale={locale}
  title={messages.auth.title}
  description={messages.auth.description}
>
  <div class="border-y border-amber-300 bg-amber-100 text-amber-950 dark:border-amber-500/40 dark:bg-amber-950 dark:text-amber-50" role="status">
    <div class="container flex flex-col gap-1 py-3 text-sm sm:flex-row sm:items-center sm:justify-center sm:gap-2 sm:text-center">
      <span class="font-bold">Discord sign-in issues:</span>
      <span>You may experience issues signing in with Discord. Please try logging in with your email and password. If no password exists, click the "Forgot Password" link.</span>
    </div>
  </div>
  <AuthPage client:load apiBaseUrl={apiBaseUrl} locale={locale} />
</Layout>
