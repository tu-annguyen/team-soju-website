---
import Layout from '../layouts/Layout.astro';
import FeebasTileChecker from '../components/feebas-tile-checker/FeebasTileChecker.tsx';
import FeebasPageIntro from '../components/feebas-tile-checker/FeebasPageIntro';

const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8787/api';
---

<Layout
  title="Feebas Tile Checker - Team Soju"
  description="Coordinate Feebas tile checks live with a shared board."
>
  <FeebasPageIntro client:load />

  <section class="py-12">
    <div class="container">
      <FeebasTileChecker client:load apiBaseUrl={apiBaseUrl} />
    </div>
  </section>
</Layout>
