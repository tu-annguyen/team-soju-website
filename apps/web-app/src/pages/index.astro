---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero';
import TeamLinks from '../components/TeamLinks';
import TeamStaff from '../components/TeamStaff';
import { getTranslations, resolveLocale } from '../i18n';

const locale = resolveLocale(Astro.url.searchParams.get('lang'));
const messages = getTranslations(locale);
---

<Layout 
  locale={locale}
  title={messages.home.title}
  description={messages.home.description}
>
  <Hero client:load locale={locale} />
  <TeamLinks client:load />
  <TeamStaff client:load />
</Layout>
