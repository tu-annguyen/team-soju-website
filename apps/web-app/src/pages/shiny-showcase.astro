---
import Layout from '../layouts/Layout.astro';
import ShinyShowcase from '../components/ShinyShowcase';

const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:3001/api';
---

<Layout 
  title="Shiny Showcase - Team Soju" 
  description="Explore Team Soju's collection of rare shiny Pokémon."
>
  <div class="py-16 bg-gradient-to-br from-primary-50 to-secondary-50 dark:from-gray-900 dark:to-gray-800">
    <div class="container">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-gray-900 dark:text-white">
          Shiny Showcase
        </h1>
        <p class="text-gray-700 dark:text-gray-300 max-w-3xl mx-auto">
          Our team's collection of rare and valuable shiny Pokémon. This page is updated using our in house Discord application.
          <a href="./discord" class="text-primary-600 dark:text-primary-400 hover:underline ml-1">Join our Discord server</a> to add your shinies today!
        </p>
      </div>
      <div class="mb-12 flex justify-center">
        <a href="./monthly-shinies" class="mx-4 btn btn-secondary">See shinies by month</a>
      </div>
    </div>
  </div>
  
  <ShinyShowcase client:load apiBaseUrl={apiBaseUrl} />
</Layout>
