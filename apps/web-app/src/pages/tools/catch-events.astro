---
import Layout from '../../layouts/Layout.astro';
import CatchEventManager from '../../components/CatchEventManager';

const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8787/api';
---

<Layout
  title="Catch Event Manager - Team Soju"
  description="Create PokeMMO catch events, collect submissions, calculate scores, and generate leaderboards."
>
  <CatchEventManager client:load apiBaseUrl={apiBaseUrl} />
</Layout>
