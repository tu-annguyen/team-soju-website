{
  "name": "team-soju",
  "version": "1.0.0",
  "description": "Welcome to the official [Team SOJU website](https://team-soju.netlify.app)! This site serves as the central hub for Team SOJU, featuring our shiny showcase, team staff, events, and more.",
  "repository": "git@github.com:tu-annguyen/team-soju-website.git",
  "author": "Tu-An Nguyen (https://tu-annguyen.com)",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@team-soju/web-app",
    "dev:api": "npm run dev:worker --workspace=@team-soju/api-server",
    "dev:api:worker": "npm run dev:api",
    "dev:api:staging": "npm run dev:worker:staging --workspace=@team-soju/api-server",
    "dev:api:express": "npm run dev:express --workspace=@team-soju/api-server",
    "dev:bot": "npm run dev --workspace=@team-soju/discord-bot",
    "dev:bot:local": "npm run dev:local --workspace=@team-soju/discord-bot",
    "dev:bot:staging": "npm run dev:staging --workspace=@team-soju/discord-bot",
    "dev:bot:staging:local": "npm run dev:staging:local --workspace=@team-soju/discord-bot",
    "dev:bot:express": "npm run dev:express --workspace=@team-soju/discord-bot",
    "dev:bot:tunnel": "ngrok http 8787",
    "dev:web:staging": "PUBLIC_API_BASE_URL=https://team-soju-api-staging.tunacore.workers.dev/api npm run dev:web",
    "tail:api:staging": "npm run tail:cf:staging --workspace=@team-soju/api-server",
    "tail:bot:staging": "npm run tail:cf:staging --workspace=@team-soju/discord-bot",
    "dev": "concurrently --kill-others-on-fail -n web,api,bot -c cyan,green,magenta \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:bot:local\"",
    "dev:staging": "concurrently --kill-others-on-fail -n web,api,bot -c cyan,green,magenta \"npm run dev:web:staging\" \"npm run dev:api:staging\" \"npm run dev:bot:staging:local\"",
    "dev:worker": "npm run dev",
    "build": "npm run build --workspace=@team-soju/web-app",
    "start": "npm run start:api",
    "start:api": "npm run start --workspace=@team-soju/api-server",
    "start:api:express": "npm run start:express --workspace=@team-soju/api-server",
    "start:bot": "npm run start --workspace=@team-soju/discord-bot",
    "start:bot:express": "npm run start:express --workspace=@team-soju/discord-bot",
    "start:bot:tunnel": "ngrok http 8787",
    "test:web": "npm run test --workspace=@team-soju/web-app -- --runInBand --coverage",
    "test:api": "npm run test --workspace=@team-soju/api-server -- --runInBand --coverage",
    "test:bot": "npm run test --workspace=@team-soju/discord-bot -- --runInBand --coverage",
    "test": "concurrently \"npm run test:api\" \"npm run test:web\""
  },
  "keywords": [
    "pokemmo",
    "pokemon",
    "api",
    "discord",
    "bot"
  ],
  "devDependencies": {
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=20"
  }
}
